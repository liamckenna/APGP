{
  "active_shader":  "default",
  "shader_programs": {
    "default": {
      "vertex": "default.vs.glsl",
      "fragment": "default.fs.glsl"
    },
    "pbr": {
      "vertex": "pbr.vs.glsl",
      "fragment": "pbr.fs.glsl"
    },
    "surface": {
      "vertex": "default.vs.glsl",
      "tess_control": "default.tcs.glsl",
      "tess_eval": "default.tes.glsl",
      "fragment": "default.fs.glsl"
    },
    "default_screen_quad": {
      "vertex": "default_screen_quad.vs.glsl",
      "fragment": "default_screen_quad.fs.glsl"
    },
    "fxaa": {
      "vertex": "default_screen_quad.vs.glsl",
      "fragment": "fxaa.fs.glsl",
      "inputs": [
        "screenSize"
      ]
    },
    "motion_blur": {
      "vertex": "default_screen_quad.vs.glsl",
      "fragment": "motion_blur.fs.glsl",
      "inputs": [
        "screenWidth",
        "depthTexture",
        "invViewProj",
        "prevViewProj",
        "deltaTime"
      ]
    },
    "render_pass": {
      "vertex": "render_pass.vs.glsl",
      "tess_control": "render_pass.tcs.glsl",
      "tess_eval": "render_pass.tes.glsl",
      "fragment": "render_pass.fs.glsl"
    },
    "patch_tess_pass": {
      "compute": "patch_tess_pass.cs.glsl"
    }
  },
  "uniforms": {
    "ambient_intensity": 0.001
  }
}
